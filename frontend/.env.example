# Base URL of the WarehouseLens backend, used by server components / server actions.
# Inside docker-compose this is the backend service name; locally use http://localhost:8000.
API_URL=http://backend:8000

# Public (browser-visible) configuration.
NEXT_PUBLIC_APP_NAME=WarehouseLens

# TODO(learning): Keycloak configuration will live here once auth is implemented, e.g.
# KEYCLOAK_ISSUER=http://keycloak:8080/realms/warehouselens
# KEYCLOAK_CLIENT_ID=warehouselens-frontend
# KEYCLOAK_CLIENT_SECRET=...   (only for a confidential client)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=...
